[node name="Story" type="Label" parent="IntroOverlay/VBox"]
theme_override_colors/font_color = Color(0.85, 0.95, 0.78, 1)
theme_override_font_sizes/font_size = 24
text = "문명이 무너진 지 100년.
정글이 도시를, 사람을, 기억을 삼켰다.

당신은 마지막 생존자들을 이끌고
폐허 속에 새 부락을 세운다.

낮엔 모으고 짓고, 밤엔 맞서 싸워라.
정글의 지배자를 쓰러뜨리는 그날까지."
horizontal_alignment = 1
autowrap_mode = 2

