[node name="Story" type="Label" parent="EndingOverlay/VBox"]
theme_override_colors/font_color = Color(0.88, 0.95, 0.8, 1)
theme_override_font_sizes/font_size = 28
text = "정글의 지배자가 쓰러졌다.

