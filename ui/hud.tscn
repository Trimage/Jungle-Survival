[node name="Body" type="Label" parent="HelpPanel/Margin/VBox"]
theme_override_font_sizes/font_size = 18
text = "• 이동: 화면 왼쪽을 드래그
• 행동: 채집 / 영입 / 직업변경 / 공격 (상황별)
• 회피: 짧게 대시하며 무적
• 가방: 자원 확인 + 아이템 탭해 사용/장착
   (음식·물=회복, 돌칼=공격력, 횃불=야간 시야)
• 제작: 도구·음식·약 (일부는 작업대 필요)
• 건설: 모닥불(안전지대)·작업대·가시방벽·오두막
• 오두막: 부락 정원↑ → 떠돌이가 더 모임
• 부락민 직업: 채집/사냥/정비/약초(치유)/요리
• 미니맵(우상단): 자원·적·건물·부락민 위치
• 밤: 맹수가 부락민·건물도 공격! 보호 필수
   (3일째 보스, 5일째 최종 보스)
• 위쪽 II: 일시정지 / 저장·불러오기"
autowrap_mode = 2

